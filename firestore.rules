rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Use exists/get for role check. Note: this env does not have custom claims.
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validators ---

    function isValidUser(data) {
      // Basic type and size checks
      return data.email is string && data.email.size() <= 200
          && data.role in ['admin', 'teacher', 'student']
          && (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100)
          && (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 2000)
          && (data.get('targetScore', 7.5) is number && data.get('targetScore', 7.5) >= 0 && data.get('targetScore', 7.5) <= 9)
          && (data.get('credits', 0) is number && data.get('credits', 0) >= 0)
          && (data.get('points', 0) is number && data.get('points', 0) >= 0)
          && (data.get('referralCode', '') is string && data.get('referralCode', '').size() <= 20)
          && (data.get('referredBy', '') is string && data.get('referredBy', '').size() <= 128)
          && (data.get('subscriptionTier', 'free') in ['free', 'pro', 'unlimited']);
    }

    function isValidTransaction(data) {
      return data.amount is number
          && data.type in ['purchase', 'usage', 'refund', 'bonus']
          && data.timestamp == request.time;
    }

    function isValidSpeakingSession(data) {
      return data.userId == request.auth.uid
          && data.transcript is list;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Owners can see their own profile, Admins can see any
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      // Creation only for self, with email verification if preferred but at least owner check
      allow create: if isOwner(userId) 
                    && isValidUser(incoming())
                    && incoming().role == 'student'
                    && incoming().credits == 10
                    && incoming().subscriptionTier == 'free'
                    && (incoming().get('createdAt', request.time) == request.time);

      allow update: if (isOwner(userId) && (
                      // Strict update path for students - cannot change their own role
                      incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'photoURL', 'targetScore', 'updatedAt', 'credits', 'subscriptionTier', 'points', 'referralCode', 'referredBy'])
                      && (incoming().get('updatedAt', request.time) == request.time)
                      && (incoming().role == existing().role)
                      && isValidUser(incoming())
                    )) || isAdmin();
      
      allow delete: if isAdmin();

      // User transactions
      match /transactions/{txId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidTransaction(incoming()) && isValidId(txId);
      }

      // Subcollection for sessions - Relational Sync Pattern
      match /speakingSessions/{sessionId} {
        allow get, list: if isOwner(userId) || isAdmin();
        
        allow create: if isOwner(userId) 
                      && isValidSpeakingSession(incoming())
                      && (incoming().get('date', request.time) == request.time)
                      && isValidId(sessionId);

        allow update: if (isOwner(userId) && (
                        // Fields used in saveSpeakingSession
                        incoming().diff(existing()).affectedKeys().hasOnly(['transcript', 'feedback', 'overallBand', 'updatedAt', 'scores'])
                        && (incoming().get('updatedAt', request.time) == request.time)
                        && isValidSpeakingSession(incoming())
                      )) || isAdmin();

        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // --- Global Reward Collections ---

    match /referrals/{refId} {
      allow get: if isSignedIn() && (isOwner(resource.data.referrerId) || isOwner(resource.data.refereeId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(request.resource.data.referrerId) || isAdmin() || (request.query.limit <= 100 && resource.data.referrerId == request.auth.uid));
      allow create: if isSignedIn() && incoming().refereeId == request.auth.uid && isValidId(refId);
      allow update, delete: if isAdmin();
    }

    match /redemptions/{redId} {
      allow get, list: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidId(redId);
      allow update, delete: if isAdmin();
    }
  }
}
