{
  "entities": {
    "SpeakingSession": {
      "title": "Speaking Session",
      "description": "A record of an ieltshub Speaking mock test session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "transcript": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sender": { "type": "string", "enum": ["Examiner", "You"] },
              "text": { "type": "string" }
            }
          }
        },
        "feedback": { "type": "string" },
        "overallBand": { "type": "number" },
        "audioBlobId": { "type": "string", "description": "Reference to locally stored audio in IndexedDB" }
      },
      "required": ["userId", "date", "transcript"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile and settings.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student"] },
        "targetScore": { "type": "number" },
        "credits": { "type": "number", "description": "Current credit balance" },
        "points": { "type": "number", "description": "Reward points balance" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string", "description": "UID of the user who referred this user" },
        "subscriptionTier": { "type": "string", "enum": ["free", "pro", "unlimited"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "credits", "subscriptionTier", "createdAt"]
    },
    "CreditTransaction": {
      "title": "Credit Transaction",
      "description": "History of credit usage and path purchases.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["purchase", "usage", "refund", "bonus"] },
        "module": { "type": "string", "enum": ["Listening", "Reading", "Writing", "Speaking"] },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "type", "description", "timestamp"]
    },
    "Referral": {
      "title": "Referral Record",
      "description": "A record of a successful referral.",
      "type": "object",
      "properties": {
        "referrerId": { "type": "string" },
        "refereeId": { "type": "string" },
        "refereeName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "pointsAwarded": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["referrerId", "refereeId", "status", "pointsAwarded", "timestamp"]
    },
    "RewardRedemption": {
      "title": "Reward Redemption",
      "description": "A record of points being redeemed for rewards.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "pointsSpent": { "type": "number" },
        "rewardType": { "type": "string", "enum": ["credits", "subscription_discount"] },
        "rewardValue": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "pointsSpent", "rewardType", "rewardValue", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/users/{userId}/speakingSessions/{sessionId}": {
      "schema": "SpeakingSession",
      "description": "Collection of speaking sessions nested under the user."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "CreditTransaction",
      "description": "User transaction history."
    },
    "/referrals/{referralId}": {
      "schema": "Referral",
      "description": "Global collection of referrals."
    },
    "/redemptions/{redemptionId}": {
      "schema": "RewardRedemption",
      "description": "Global collection of point redemptions."
    }
  }
}
