{
  "entities": {
    "SpeakingSession": {
      "title": "Speaking Session",
      "description": "A record of an ieltshub Speaking mock test session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "transcript": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sender": { "type": "string", "enum": ["Examiner", "You"] },
              "text": { "type": "string" }
            }
          }
        },
        "feedback": { "type": "string" },
        "overallBand": { "type": "number" },
        "audioBlobId": { "type": "string", "description": "Reference to locally stored audio in IndexedDB" }
      },
      "required": ["userId", "date", "transcript"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile and settings.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student"] },
        "targetScore": { "type": "number" },
        "credits": { "type": "number", "description": "Current credit balance" },
        "subscriptionTier": { "type": "string", "enum": ["free", "pro", "unlimited"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "credits", "subscriptionTier", "createdAt"]
    },
    "CreditTransaction": {
      "title": "Credit Transaction",
      "description": "History of credit usage and path purchases.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["purchase", "usage", "refund", "bonus"] },
        "module": { "type": "string", "enum": ["Listening", "Reading", "Writing", "Speaking"] },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "type", "description", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/users/{userId}/speakingSessions/{sessionId}": {
      "schema": "SpeakingSession",
      "description": "Collection of speaking sessions nested under the user."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "CreditTransaction",
      "description": "User transaction history."
    }
  }
}
